# =============================================================================
# UnifiedOps v2 — Vite dev-server env
#
# Copy this file to `frontend/.env.development` and adjust as needed. Vite
# loads it automatically when `npm run dev` is invoked.
#
# Three InfluxDB instances are proxied directly so the browser can issue
# ad-hoc Flux queries via `services/alerts/api/influx.ts` without CORS
# headaches. The FastAPI server (server.py + health_check.py) is proxied
# on /api and /ws — same-origin from the browser's point of view.
# =============================================================================

# --- FastAPI (server.py + health_check.py) ----------------------------------
# /api/* and /ws/* on the dev origin will reverse-proxy here.
VITE_DEV_API_TARGET=http://127.0.0.1:8001

# --- Per-location InfluxDB direct proxies (local podman) --------------------
# /influx       -> CDVL
# /influx-bcp   -> BCP
# /influx-sify  -> SIFY
VITE_DEV_INFLUX_CDVL_TARGET=http://127.0.0.1:8086
VITE_DEV_INFLUX_BCP_TARGET=http://127.0.0.1:8087
VITE_DEV_INFLUX_SIFY_TARGET=http://127.0.0.1:8088

# --- Trap-sender microservice (dev only) ------------------------------------
# /trap/* on the dev origin reverse-proxies here so the dashboard can link
# to the manual trap sender in a sibling tab without origin mismatch.
VITE_DEV_TRAP_UI_TARGET=http://127.0.0.1:7700
