# UnifiedOps dev podman-compose env file.
# Copy to `.env` next to podman-compose.yml. Three InfluxDB instances
# are launched, one per location (CDVL / BCP / SIFY), each on its own
# host port. These values are ONLY for the local Podman setup;
# production tokens live in /etc/hi-track/listener.<loc>.env and
# /etc/hi-track/ui.env on the airgapped RHEL VMs.

# --- Host ports (each forwards to the container's :8086) -----------------
INFLUX_CDVL_HOST_PORT=8086
INFLUX_BCP_HOST_PORT=8087
INFLUX_SIFY_HOST_PORT=8088

# --- Initial admin user (created on first run only) ----------------------
# Same admin user across all three instances so the bootstrap script's
# CLI calls stay simple. Tokens are still per-instance.
INFLUX_USERNAME=admin
INFLUX_PASSWORD=adminadmin

# --- Org + retention (same for all three) --------------------------------
INFLUX_ORG=HDFC
INFLUX_RETENTION=0

# --- Per-location buckets -----------------------------------------------
# Defaults match what each listener_<loc>.py writes to by default, so the
# launchers can talk to dev Influx with no env tweaks beyond URL+TOKEN.
INFLUX_CDVL_BUCKET=SYSLOG_HIT_Bucket
INFLUX_BCP_BUCKET=SYSLOG_HIT_BCP_Bucket
INFLUX_SIFY_BUCKET=SYSLOG_HIT_SIFY_Bucket

# --- Per-location all-access admin tokens --------------------------------
# Each container gets its own token. Rotate freely in dev.
INFLUX_CDVL_TOKEN=unifiedops-dev-token-cdvl
INFLUX_BCP_TOKEN=unifiedops-dev-token-bcp
INFLUX_SIFY_TOKEN=unifiedops-dev-token-sify
