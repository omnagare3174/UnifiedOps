# Hi-Track listener - SIFY location overrides.
# Copy to /etc/hi-track/listener.sify.env on the SIFY pipeline VM and edit.
# Loaded by systemd via EnvironmentFile= in hi-track-listener-sify.service.
#
# The standalone listener `syslog_trap_listener_sify.py` already presets
# the bucket name and embeds the IP maps for SIFY. You only need to
# override the few values below.

# --- Influx (local on this VM) ----------------------------------------
HITRACK_INFLUX_URL=http://127.0.0.1:8086

# Influx auth (REQUIRED - do not ship real tokens in source).
HITRACK_INFLUX_TOKEN=replace-me-with-a-strong-token
HITRACK_INFLUX_ORG=HDFC

# Bucket override (default in code: SYSLOG_HIT_SIFY_Bucket).
# HITRACK_INFLUX_BUCKET=SYSLOG_HIT_SIFY_Bucket

# --- Listener bind -----------------------------------------------------
HITRACK_LISTEN_HOST=0.0.0.0
HITRACK_LISTEN_PORT=514

HITRACK_TEST_MODE=0
