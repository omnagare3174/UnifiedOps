# Hi-Track listener - BCP location overrides.
# Copy to /etc/hi-track/listener.bcp.env on the BCP pipeline VM and edit.
# Loaded by systemd via EnvironmentFile= in hi-track-listener-bcp.service.
#
# The standalone listener `syslog_trap_listener_bcp.py` already presets
# the bucket name and embeds the IP maps for BCP. You only need to
# override the few values below.

# --- Influx (local on this VM) ----------------------------------------
HITRACK_INFLUX_URL=http://127.0.0.1:8086

# Influx auth (REQUIRED - do not ship real tokens in source).
HITRACK_INFLUX_TOKEN=replace-me-with-a-strong-token
HITRACK_INFLUX_ORG=HDFC

# Bucket override (default in code: SYSLOG_HIT_BCP_Bucket).
# HITRACK_INFLUX_BUCKET=SYSLOG_HIT_BCP_Bucket

# --- Listener bind -----------------------------------------------------
HITRACK_LISTEN_HOST=0.0.0.0
HITRACK_LISTEN_PORT=514

HITRACK_TEST_MODE=0
