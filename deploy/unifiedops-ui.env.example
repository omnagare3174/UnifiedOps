# =============================================================================
# UnifiedOps v2 — Production env file (UI server)
#
# Install: copy to /etc/unifiedops/ui.env on the UI RHEL VM and chmod 0640.
# Loaded by both unifiedops-ui-server.service (server.py) and
# unifiedops-health-check.service (health_check.py).
#
# The 4-VM topology this file targets:
#
#   listener-cdvl-vm      runs all 4 listeners + alert InfluxDB + heartbeat InfluxDB
#   listener-bcp-vm       runs all 4 listeners + alert InfluxDB + heartbeat InfluxDB
#   listener-sify-vm      runs all 4 listeners + alert InfluxDB + heartbeat InfluxDB
#   ui-vm  (THIS HOST)    runs server.py + health_check.py + serves React UI
# =============================================================================

# --- FastAPI listen address -------------------------------------------------
HITRACK_UI_HOST=0.0.0.0
HITRACK_UI_PORT=8001
HITRACK_UI_DIST=/opt/unifiedops/frontend/dist

# Optional TLS (terminate at nginx in front for prod; leave blank here).
HITRACK_UI_TLS_CERT=
HITRACK_UI_TLS_KEY=
HITRACK_UI_TLS_KEY_PASSWORD=

# --- Alert InfluxDBs (one per listener VM) ---------------------------------
HITRACK_INFLUX_CDVL_URL=https://listener-cdvl-vm.internal:8086
HITRACK_INFLUX_CDVL_TOKEN=
HITRACK_INFLUX_CDVL_ORG=HDFC
HITRACK_INFLUX_CDVL_BUCKET=SYSLOG_HIT_Bucket

HITRACK_INFLUX_BCP_URL=https://listener-bcp-vm.internal:8086
HITRACK_INFLUX_BCP_TOKEN=
HITRACK_INFLUX_BCP_ORG=HDFC
HITRACK_INFLUX_BCP_BUCKET=SYSLOG_HIT_BCP_Bucket

HITRACK_INFLUX_SIFY_URL=https://listener-sify-vm.internal:8086
HITRACK_INFLUX_SIFY_TOKEN=
HITRACK_INFLUX_SIFY_ORG=HDFC
HITRACK_INFLUX_SIFY_BUCKET=SYSLOG_HIT_SIFY_Bucket

# --- Heartbeat InfluxDBs (one per listener VM) -----------------------------
HITRACK_HEARTBEAT_CDVL_URL=https://listener-cdvl-vm.internal:8486
HITRACK_HEARTBEAT_CDVL_TOKEN=
HITRACK_HEARTBEAT_CDVL_ORG=HDFC
HITRACK_HEARTBEAT_CDVL_BUCKET=CDVL_Heartbeat_Bucket

HITRACK_HEARTBEAT_BCP_URL=https://listener-bcp-vm.internal:8486
HITRACK_HEARTBEAT_BCP_TOKEN=
HITRACK_HEARTBEAT_BCP_ORG=HDFC
HITRACK_HEARTBEAT_BCP_BUCKET=BCP_Heartbeat_Bucket

HITRACK_HEARTBEAT_SIFY_URL=https://listener-sify-vm.internal:8486
HITRACK_HEARTBEAT_SIFY_TOKEN=
HITRACK_HEARTBEAT_SIFY_ORG=HDFC
HITRACK_HEARTBEAT_SIFY_BUCKET=SIFY_Heartbeat_Bucket

# --- Poll cadences ----------------------------------------------------------
# server.py — alert scrape
HITRACK_PIPELINE_POLL_SECS=5
# health_check.py — heartbeat poll
HITRACK_LISTENER_POLL_SECS=10
HITRACK_LISTENER_DOWN_THRESHOLD_S=30

# --- Threadpool + httpx pool for multithreaded backend ---------------------
HITRACK_THREAD_WORKERS=64
HITRACK_HTTPX_MAX_CONNECTIONS=200
HITRACK_HTTPX_MAX_KEEPALIVE=64

# --- Misc -------------------------------------------------------------------
HITRACK_VERIFY_TLS=1
HITRACK_CORS_ORIGINS=*
HITRACK_DASH_CACHE_TTL=3.0
