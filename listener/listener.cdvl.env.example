# Hi-Track listener - CDVL location overrides.
# Copy to /etc/hi-track/listener.cdvl.env on the CDVL pipeline VM and edit.
# Loaded by systemd via EnvironmentFile= in hi-track-listener-cdvl.service.
#
# The standalone listener `syslog_trap_listener_cdvl.py` already presets
# the bucket name and embeds the IP maps for CDVL. You only need to
# override the few values below.

# --- Influx (local on this VM) ----------------------------------------
# Each pipeline VM runs a LOCAL InfluxDB on 127.0.0.1:8086 (HTTP). Switch
# to https:// only if the local InfluxDB is fronted by TLS.
HITRACK_INFLUX_URL=http://127.0.0.1:8086

# Influx auth (REQUIRED - do not ship real tokens in source).
HITRACK_INFLUX_TOKEN=replace-me-with-a-strong-token
HITRACK_INFLUX_ORG=HDFC

# Bucket override (default in code: SYSLOG_HIT_Bucket).
# HITRACK_INFLUX_BUCKET=SYSLOG_HIT_Bucket

# --- Listener bind -----------------------------------------------------
# Standard syslog port. AmbientCapabilities=CAP_NET_BIND_SERVICE in the
# unit file lets the hitrack user bind <1024 without root.
HITRACK_LISTEN_HOST=0.0.0.0
HITRACK_LISTEN_PORT=514

# Leave at 0 in production. =1 enables verbose test/loopback logging.
HITRACK_TEST_MODE=0
